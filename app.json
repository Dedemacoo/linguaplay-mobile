{
  "expo": {
    "name": "LinguaPlay",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/lingo_splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#080C16"
    },
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Lingo AI ile konuşabilmeniz için mikrofona ihtiyacımız var.",
        "NSSpeechRecognitionUsageDescription": "Telaffuzunuzu değerlendirebilmek için konuşma tanıma iznine ihtiyacımız var."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.linguaplay",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#00D2FF",
          "defaultChannel": "reminders"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-speech-recognition",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "eas": {
        "projectId": "8b8d9efb-e793-4b1c-b7ca-c9dd64885e4b"
      }
    }
  }
}
